<UserControl x:Class="FMFCBuildTool.Views.PackageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FMFCBuildTool.Views"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
 <!-- MAIN -->

        <Grid Margin="20">

            <Grid.RowDefinitions>
                
                    <RowDefinition Height="Auto"/> <!-- Project -->
                    <RowDefinition Height="Auto"/> <!-- Engine -->
                    <RowDefinition Height="Auto"/> <!-- Build Options -->
                    <RowDefinition Height="*"/>  <!-- Maps -->
                    <RowDefinition Height="Auto"/> <!-- Buttons -->

                </Grid.RowDefinitions>

        
                        <!-- PROJECT -->

            <GroupBox
                Grid.Row="0"
                Header="Project"
                Margin="0,0,0,15"
                Foreground="White">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="ProjectTextBox"
                        Margin="0,0,10,0"/>

                    <Button
                        Grid.Column="1"
                        Click="BrowseProject_Click"
                        Content="Browse"/>

                </Grid>

            </GroupBox>
                        
            <!-- BUILD OPTIONS -->
                <GroupBox
    Grid.Row="2"
    Header="Build Options"
    Margin="0,0,0,15"
    Foreground="White">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="140"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Archive -->

        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="Archive Folder"/>

        <DockPanel
            Grid.Row="0"
            Grid.Column="1">

            <TextBox
                x:Name="ArchiveTextBox"
                Padding="0,0,0,0"
                Margin="0,0,0,0"/>

            <Button
                Width="40"
                Height="20"
                Margin="5,5,5,5"
                Click="BrowseArchive_Click"
                Content="Browse"/>

        </DockPanel>

        <!-- Configuration -->

        <TextBlock
            Grid.Row="0"
            Padding="5,0,5,0"
            Grid.Column="3"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Text="Configuration"/>

        <ComboBox
            x:Name="ConfigurationComboBox"
            Grid.Row="0"
            Grid.Column="4"
            Padding="5,0,5,0"
            VerticalAlignment="Center"
            Foreground="Black"
            SelectedIndex="0">

            <ComboBoxItem Content="Shipping"/>
            <ComboBoxItem Content="Development"/>
            <ComboBoxItem Content="DebugGame"/>

        </ComboBox>
        <TextBlock
            Grid.Row="0"
            Grid.Column="5"
            Margin="15,0,5,0"
            VerticalAlignment="Center"
            Text="Culture"/>

        <ComboBox
            x:Name="CookCultureComboBox"
            Grid.Row="0"
            Grid.Column="6"
            Width="120"
            SelectedIndex="0"
            Foreground="Black">

            <ComboBoxItem Content="en"/>
            <ComboBoxItem Content="es"/>
            <ComboBoxItem Content="fr"/>
            <ComboBoxItem Content="de"/>
            <ComboBoxItem Content="it"/>
            <ComboBoxItem Content="pt-BR"/>
            <ComboBoxItem Content="ja"/>
            <ComboBoxItem Content="ko"/>
            <ComboBoxItem Content="zh-Hans"/>
            <ComboBoxItem Content="zh-Hant"/>
            <ComboBoxItem Content="ru"/>

        </ComboBox>
        <!-- Build Options -->

        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Top"
            Margin="0,8,0,0"
            Text="Packaging"/>

        <Grid
    Grid.Row="1"
    Grid.Column="1"
    Grid.ColumnSpan="4"
    Margin="0,8,0,0">

    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220"/>
        <ColumnDefinition Width="220"/>
        <ColumnDefinition Width="220"/>
        <ColumnDefinition Width="220"/>
    </Grid.ColumnDefinitions>

    <!-- Column 1 -->

    <StackPanel Grid.Column="0">

        <CheckBox x:Name="BuildCheckBox"
                  Content="Build"
                  IsChecked="True"/>

        <CheckBox x:Name="CookCheckBox"
                  Content="Cook"
                  IsChecked="True"/>

        <CheckBox x:Name="StageCheckBox"
                  Content="Stage"
                  IsChecked="True"/>

        <CheckBox x:Name="PackageCheckBox"
                  Content="Package"
                  IsChecked="True"/>

        <CheckBox x:Name="ArchiveCheckBox"
                  Content="Archive"
                  IsChecked="True"/>

        <CheckBox x:Name="PakCheckBox"
                  Content="Pak"
                  IsChecked="True"/>

        <CheckBox x:Name="CompressedCheckBox"
                  Content="Compressed"
                  IsChecked="True"/>
        <CheckBox x:Name="CookIncrementalCheckBox"
                  Content="Cook Incremental"/>
        

    </StackPanel>

    <!-- Column 2 -->

    <StackPanel Grid.Column="1">

        <CheckBox x:Name="NoCompileCheckBox"
                  Content="No Compile"
                  IsChecked="True"/>

        <CheckBox x:Name="NoCompileEditorCheckBox"
                  Content="No Compile Editor"
                  IsChecked="True"/>

        <CheckBox x:Name="UnversionedCookedContentCheckBox"
                  Content="Unversioned Cooked Content"
                  IsChecked="True"/>
        
        <CheckBox
            x:Name="PrereqsCheckBox"
            Content="Prerequisites"/>

        <CheckBox
            x:Name="DistributionCheckBox"
            Content="Distribution"/>

        <CheckBox
            x:Name="CrashReporterCheckBox"
            Content="Crash Reporter"/>

        <CheckBox
            x:Name="ClientCheckBox"
            Content="Client"/>

        <CheckBox
            x:Name="ServerCheckBox"
            Content="Server"/>

    </StackPanel>

    <!-- Column 3 -->

    <StackPanel Grid.Column="2">

        <CheckBox x:Name="ZenStoreCheckBox"
                  Content="Zen Store"/>
        
        <CheckBox x:Name="SkipCookingEditorContentCheckBox"
                  Content="Skip Cooking Editor Content"
                  IsChecked="True"/>

        <CheckBox x:Name="FileOpenLogCheckBox"
                  Content="File Open Log"
                  IsChecked="True"/>

        <CheckBox x:Name="StdOutCheckBox"
                  Content="StdOut"
                  IsChecked="True"/>

        <CheckBox x:Name="CrashForUATCheckBox"
                  Content="Crash For UAT"
                  IsChecked="True"/>
        
        <CheckBox x:Name="UnattendedCheckBox"
                  Content="Unattended"
                  IsChecked="True"/>

        <CheckBox x:Name="NoLogTimesCheckBox"
                  Content="No Log Times"
                  IsChecked="True"/>

    </StackPanel>

    <!-- Column 4 -->

    <StackPanel Grid.Column="3">

 

    </StackPanel>

</Grid>
        <!-- Cook Mode -->

        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,20,0,0"
            VerticalAlignment="Center"
            Text="Cook Mode"/>

        <StackPanel
            Grid.Row="2"
            Grid.Column="1"
            Grid.ColumnSpan="4"
            Margin="0,20,0,0"
            Orientation="Horizontal">

            <RadioButton
                x:Name="ModifiedCookRadio"
                Content="Modified"
                IsChecked="True"
                Margin="0,0,20,0"/>

            <RadioButton
                x:Name="FullCookRadio"
                Content="Full Cook"/>

        </StackPanel>

    </Grid>

</GroupBox>
                        
                        <!-- MAPS -->

            <GroupBox
                Grid.Row="3"
                Header="Maps"
                Margin="0,0,0,15"
                Foreground="White">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">

                        <TextBox
                            x:Name="MapSearchTextBox"
                            Height="35"
                            Width="400"
                            FontSize="16"
                            Padding="10,5"
                            VerticalContentAlignment="Center"
                            TextChanged="MapSearchTextBox_TextChanged"
                        />

                        <CheckBox
                            x:Name="UseProjectDefaultMapsCheckBox"
                            Margin="20,4,0,0"
                            Content="Use project default maps"
                            IsChecked="True"/>

                    </DockPanel>

                    <ListView
                        x:Name="MapsListView"
                        Grid.Row="1"

                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListView.View>

                            <GridView>

                                <GridViewColumn Header="✓" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                IsChecked="{Binding Selected, Mode=TwoWay}"
                                                HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>


                                <GridViewColumn
                                    Header="Map"
                                    Width="220"
                                    DisplayMemberBinding="{Binding Name}"/>


                                <GridViewColumn
                                    Header="Path"
                                    Width="650"
                                    DisplayMemberBinding="{Binding RelativePath}"/>

                            </GridView>

                        </ListView.View>

                    </ListView>

                    <StackPanel
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                        <Button
                            Width="120"
                            Margin="0,0,10,0"
                            Content="Select All"
                            Click="SelectAllMaps_Click"/>

                        <Button
                            Width="120"
                            Content="Deselect All"
                            Click="DeselectAllMaps_Click"/>

                        <Button
                            Width="120"
                            Content="Clear"/>

                    </StackPanel>

                </Grid>

            </GroupBox>

            <!-- OUTPUT 

            <GroupBox
                Grid.Row="4"
                Header="Output"
                Margin="0,0,0,15"
                Foreground="White">

                <TextBox
                    x:Name="OutputTextBox"
                    Margin="10"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    TextWrapping="NoWrap"/>

            </GroupBox>-->

            <!-- BUTTONS -->

            <StackPanel
                Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right">

                <Button
                    x:Name="CancelButton"
                    Width="150"
                    Height="45"
                    Margin="0,0,10,0"
                    Content="Cancel"/>

                <TextBlock
                    x:Name="BuildTimeText"
                    Text="Ready"
                    FontSize="14"
                    Foreground="White"
                    Margin="10"/>
                
                <Button
                    x:Name="BuildButton"
                    Width="220"
                    Height="45"
                    FontSize="18"
                    FontWeight="Bold"
                    Content="BUILD"/>

            </StackPanel>

        </Grid>
</UserControl>
