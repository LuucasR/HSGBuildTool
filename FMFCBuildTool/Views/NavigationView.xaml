<UserControl x:Class="FMFCBuildTool.Views.NavigationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- PROJECT -->

        <GroupBox Header="Navigation Project">

            <Grid Height="55" Margin="10">

                <TextBox x:Name="ProjectTextBox"
                         IsReadOnly="True"
                         VerticalAlignment="Center"/>

            </Grid>

        </GroupBox>


        <!-- MAPS -->

        <GroupBox Grid.Row="1"
                  Header="Maps"
                  Margin="0,15,0,15">

            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">

                    <Button Content="Select All"
                            Width="120"
                            Click="SelectAllMaps_Click"/>

                    <Button Content="Deselect All"
                            Width="120"
                            Margin="10,0,0,0"
                            Click="DeselectAllMaps_Click"/>

                </StackPanel>

                <ListView Grid.Row="1"
                          Margin="0,10,0,0"
                          x:Name="MapsListView">

                    <ListView.View>

                        <GridView>

                            <GridViewColumn Header="Selected"
                                            Width="80">

                                <GridViewColumn.CellTemplate>

                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Selected}"/>
                                    </DataTemplate>

                                </GridViewColumn.CellTemplate>

                            </GridViewColumn>

                            <GridViewColumn Header="Map"
                                            DisplayMemberBinding="{Binding Name}"
                                            Width="250"/>

                            <GridViewColumn Header="Path"
                                            DisplayMemberBinding="{Binding RelativePath}"
                                            Width="500"/>

                        </GridView>

                    </ListView.View>

                </ListView>

            </Grid>

        </GroupBox>


        <!-- ENGINE -->

        <GroupBox Grid.Row="2"
                  Header="Unreal Engine"
                  Margin="0,0,0,15">

            <Grid Height="55" Margin="10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="EngineTextBox"
                         IsReadOnly="True"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Browse"
                        Height="35"
                        VerticalAlignment="Center"
                        Click="BrowseEngine_Click"/>

            </Grid>

        </GroupBox>


        <!-- ACTIONS -->

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="BUILD NAV"
                    Width="150"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="BuildNav_Click"/>

            <Button Content="DELETE NAV"
                    Width="150"
                    Height="40"
                    Click="DeleteNav_Click"/>

        </StackPanel>

    </Grid>

</UserControl>