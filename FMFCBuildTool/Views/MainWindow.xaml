<Window x:Class="FMFCBuildTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FMFC Build Tool"
        Width="1500"
        Height="900"
        MinWidth="1200"
        MinHeight="800"
        WindowStartupLocation="CenterScreen">

    <DockPanel Background="#252526">

        <!-- TOP -->

        <Border DockPanel.Dock="Top"
                Height="55"
                Background="#2D2D30">

            <Grid Margin="15,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBlock
                        Text="FMFC Build Tool"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="White"/>

                    <TextBlock
                        Margin="15,4,0,0"
                        Text="v2"
                        Foreground="#AAAAAA"/>

                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Foreground="#AAAAAA"
                    Text="Heroic Spirit Games"/>

            </Grid>

        </Border>

        <!-- LEFT -->

        <Border DockPanel.Dock="Left"
                Width="240"
                Background="#2D2D30">

            <StackPanel Margin="15">

                <Button
                    Height="45"
                    Margin="0,0,0,10"
                    Content="📦 Package"/>

                <Button
                    Height="45"
                    Margin="0,0,0,10"
                    Content="🧭 Navigation"/>

                <Button
                    Height="45"
                    Margin="0,0,0,10"
                    Content="🏗 Build HLOD"/>

                <Button
                    Height="45"
                    Margin="0,0,0,10"
                    Content="💡 Lighting"/>

                <Button
                    Height="45"
                    Margin="0,0,0,25"
                    Content="⚙ Settings"/>

                <Separator/>

                <TextBlock
                    Margin="0,20,0,5"
                    Foreground="White"
                    FontWeight="Bold"
                    Text="Recent Projects"/>

                <ListBox Height="250"/>

            </StackPanel>

        </Border>

        <!-- MAIN -->

        <Grid Margin="20">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>
                        <!-- PROJECT -->

            <GroupBox
                Grid.Row="0"
                Header="Project"
                Margin="0,0,0,15"
                Foreground="White">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="ProjectTextBox"
                        Margin="0,0,10,0"/>

                    <Button
                        Grid.Column="1"
                        Click="BrowseProject_Click"
                        Content="Browse"/>

                </Grid>

            </GroupBox>

            <!-- BUILD OPTIONS -->
                <GroupBox
    Grid.Row="1"
    Header="Build Options"
    Margin="0,0,0,15"
    Foreground="White">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Archive -->

        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="Archive Folder"/>

        <DockPanel
            Grid.Row="0"
            Grid.Column="1">

            <TextBox
                x:Name="ArchiveTextBox"
                Margin="0,0,10,0"/>

            <Button
                Width="90"
                Click="BrowseArchive_Click"
                Content="Browse"/>

        </DockPanel>

        <!-- Configuration -->

        <TextBlock
            Grid.Row="0"
            Grid.Column="3"
            VerticalAlignment="Center"
            Text="Configuration"/>

        <ComboBox
            x:Name="ConfigurationComboBox"
            Grid.Row="0"
            Grid.Column="4"
            SelectedIndex="0">

            <ComboBoxItem Content="Shipping"/>
            <ComboBoxItem Content="Development"/>
            <ComboBoxItem Content="DebugGame"/>

        </ComboBox>

        <!-- Build Options -->

        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Top"
            Margin="0,8,0,0"
            Text="Packaging"/>

        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="4"
            Margin="0,8,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <CheckBox
                    x:Name="BuildCheckBox"
                    Content="Build"
                    IsChecked="True"/>

                <CheckBox
                    x:Name="CookCheckBox"
                    Content="Cook"
                    IsChecked="True"/>

                <CheckBox
                    x:Name="StageCheckBox"
                    Content="Stage"
                    IsChecked="True"/>

                <CheckBox
                    x:Name="PackageCheckBox"
                    Content="Package"
                    IsChecked="True"/>

            </StackPanel>

            <StackPanel Grid.Column="1">

                <CheckBox
                    x:Name="ArchiveCheckBox"
                    Content="Archive"
                    IsChecked="True"/>

                <CheckBox
                    x:Name="PakCheckBox"
                    Content="Pak"
                    IsChecked="True"/>

                <CheckBox
                    x:Name="CompressedCheckBox"
                    Content="Compressed"
                    IsChecked="True"/>

            </StackPanel>

        </Grid>

        <!-- Cook Mode -->

        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,20,0,0"
            VerticalAlignment="Center"
            Text="Cook Mode"/>

        <StackPanel
            Grid.Row="2"
            Grid.Column="1"
            Grid.ColumnSpan="4"
            Margin="0,20,0,0"
            Orientation="Horizontal">

            <RadioButton
                x:Name="ModifiedCookRadio"
                Content="Modified"
                IsChecked="True"
                Margin="0,0,20,0"/>

            <RadioButton
                x:Name="FullCookRadio"
                Content="Full Cook"/>

        </StackPanel>

    </Grid>

</GroupBox>
                        
                        <!-- MAPS -->

            <GroupBox
                Grid.Row="2"
                Header="Maps"
                Margin="0,0,0,15"
                Foreground="White">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">

                        <TextBox
                            Grid.Row="0"
                            x:Name="MapSearchTextBox"
                            TextChanged="MapSearchTextBox_TextChanged"/>

                        <CheckBox
                            x:Name="UseProjectDefaultMapsCheckBox"
                            Margin="20,4,0,0"
                            Content="Use project default maps"
                            IsChecked="True"/>

                    </DockPanel>

                    <ListView
                        Grid.Row="1"
                        x:Name="MapsListView">

                        <ListView.View>

                            <GridView>

                                <GridViewColumn Header="✓" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                IsChecked="{Binding Selected, Mode=TwoWay}"
                                                HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn
                                    Header="Map"
                                    Width="220"
                                    DisplayMemberBinding="{Binding Name}"/>

                                <GridViewColumn
                                    Header="Path"
                                    Width="650"
                                    DisplayMemberBinding="{Binding RelativePath}"/>

                            </GridView>

                        </ListView.View>

                    </ListView>

                    <StackPanel
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                        <Button
                            Width="120"
                            Margin="0,0,10,0"
                            Content="Select All"
                            Click="SelectAllMaps_Click"/>

                        <Button
                            Width="120"
                            Content="Deselect All"
                            Click="DeselectAllMaps_Click"/>

                        <Button
                            Width="120"
                            Content="Clear"/>

                    </StackPanel>

                </Grid>

            </GroupBox>

            <!-- OUTPUT -->

            <GroupBox
                Grid.Row="3"
                Header="Output"
                Margin="0,0,0,15"
                Foreground="White">

                <TextBox
                    x:Name="OutputTextBox"
                    Margin="10"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    TextWrapping="NoWrap"/>

            </GroupBox>

            <!-- BUTTONS -->

            <StackPanel
                Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right">

                <Button
                    x:Name="CancelButton"
                    Width="150"
                    Height="45"
                    Margin="0,0,10,0"
                    Content="Cancel"/>

                <Button
                    x:Name="BuildButton"
                    Width="220"
                    Height="45"
                    FontSize="18"
                    FontWeight="Bold"
                    Content="BUILD"/>

            </StackPanel>

        </Grid>

    </DockPanel>

</Window>