<Window x:Class="FMFCBuildTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FMFC Build Tool"
        Width="1500"
        Height="900"
        MinWidth="1200"
        MinHeight="800"
        WindowStartupLocation="CenterScreen">


    <DockPanel Background="{StaticResource BackgroundBrush}">


        <!-- TOP BAR -->

        <Border DockPanel.Dock="Top"
                Height="55"
                Background="{StaticResource PanelBrush}">

            <Grid Margin="15,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>


                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBlock
                        Text="FMFC Build Tool"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{StaticResource PrimaryBrush}"/>


                    <TextBlock
                        Margin="15,4,0,0"
                        Text="v2"
                        Foreground="{StaticResource SecondaryTextBrush}"/>

                </StackPanel>



                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="Heroic Spirit Games"/>

            </Grid>

        </Border>



        <!-- OUTPUT -->

        <GroupBox DockPanel.Dock="Bottom"
                  Height="220"
                  Margin="10"
                  Header="Output">


            <TextBox
                x:Name="OutputTextBox"

                Background="{StaticResource InputBrush}"
                Foreground="{StaticResource TextBrush}"

                IsReadOnly="True"

                TextWrapping="Wrap"

                AcceptsReturn="True"

                VerticalScrollBarVisibility="Auto"

                HorizontalScrollBarVisibility="Auto"/>


        </GroupBox>



        <!-- LEFT MENU -->

        <Border DockPanel.Dock="Left"
                Width="240"
                Background="{StaticResource PanelBrush}">


            <StackPanel Margin="15">


                <Button
                    Height="45"
                    Margin="0,0,0,10"
                    Content="📦 Package"
                    Click="Package_Click"/>



                <Button
                    Height="45"
                    Margin="0,0,0,10"
                    Content="🧭 Navigation"
                    Click="Navigation_Click"/>



                <Button
                    Height="45"
                    Margin="0,0,0,10"
                    Content="🏗 Build HLOD"/>



                <Button
                    Height="45"
                    Margin="0,0,0,10"
                    Content="💡 Lighting"/>



                <Button
                    Height="45"
                    Margin="0,0,0,25"
                    Content="⚙ Settings"/>



                <Separator/>



                <TextBlock
                    Margin="0,20,0,5"
                    Foreground="{StaticResource TextBrush}"
                    FontWeight="Bold"
                    Text="Recent Projects"/>



                <ListBox
                    Height="250"
                    Background="{StaticResource CardBrush}"/>


            </StackPanel>


        </Border>



        <!-- MAIN CONTENT -->

        <ContentControl
            x:Name="MainContent"/>


    </DockPanel>


</Window>